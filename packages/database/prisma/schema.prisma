generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?   @unique   // Custom domain, e.g. "shop.narofashion.co.tz"
  status      String    @default("ACTIVE") // ACTIVE, TRIAL, SUSPENDED, DEACTIVATED
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branding      TenantBranding?
  subscriptions TenantSubscription[]
  payments      TenantPayment[]
  modules       TenantModule[]
  adminUsers    AdminUser[]
  users         User[]

  @@index([slug])
  @@index([domain])
  @@index([status])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("PLATFORM_ADMIN") // PLATFORM_ADMIN, PLATFORM_SUPPORT
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model TenantBranding {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  companyName     String
  tagline         String?
  logoUrl         String?
  iconUrl         String?
  faviconUrl      String?
  colorPrimary    String  @default("#D4AF37")
  colorSecondary  String  @default("#1A1A1A")
  colorAccent     String  @default("#D4AF37")
  fontHeading     String  @default("Playfair Display")
  fontBody        String  @default("Inter")
  customCss       String?
  whatsappNumber  String?
  socialLinks     Json?     // { instagram, facebook, tiktok, twitter }
  metaTitle       String?
  metaDescription String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  priceMonthly   Decimal  @db.Decimal(12, 2)
  priceYearly    Decimal? @db.Decimal(12, 2)
  maxProducts    Int?                          // null = unlimited
  maxAdminUsers  Int?
  maxStorageGB   Int      @default(5)
  enabledModules String[]                      // ["products","orders","rentals","pos",...]
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id           String    @id @default(cuid())
  tenantId     String
  planId       String
  status       String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED, GRACE
  billingCycle String    @default("MONTHLY") // MONTHLY, YEARLY
  startDate    DateTime  @default(now())
  endDate      DateTime
  autoRenew    Boolean   @default(true)
  graceEndDate DateTime?                    // End of grace period after expiry
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([endDate])
  @@index([status])
}

model TenantPayment {
  id             String    @id @default(cuid())
  tenantId       String
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("TZS")
  method         String                         // MOBILE_MONEY, BANK_TRANSFER, MANUAL
  status         String    @default("PENDING")  // PENDING, COMPLETED, FAILED
  transactionRef String?   @unique
  invoiceNumber  String?   @unique
  periodStart    DateTime
  periodEnd      DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([status])
}

model TenantModule {
  id         String   @id @default(cuid())
  tenantId   String
  moduleCode String                            // "products", "orders", "rentals", "pos", etc.
  isEnabled  Boolean  @default(true)
  enabledAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, moduleCode])
  @@index([tenantId])
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  email         String?
  phone         String?
  passwordHash  String?
  firstName     String?
  lastName      String?
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  preferredTheme String   @default("standard")
  preferredLocale String  @default("en")
  googleId      String?   @unique
  facebookId    String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  rentalOrders  RentalOrder[]
  idDocuments   CustomerIDDocument[]
  referralCode  ReferralCode?
  referredBy    Referral?       @relation("referredUser")
  referrals     Referral[]      @relation("referrer")
  events        CustomerEvent[]
  layaways      Layaway[]
  promoCodeUsages PromoCodeUsage[]
  abandonedCartReminders AbandonedCartReminder[]

  alternativePhone String?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  label       String  @default("Home")
  fullName    String
  phone       String
  street      String
  city        String
  region      String
  postalCode  String?
  country     String  @default("Tanzania")
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orders Order[]

  @@index([userId])
}

model AdminUser {
  id           String   @id @default(cuid())
  tenantId     String?
  email        String   @unique  // Globally unique — no tenant context needed at admin login
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         String   @default("STAFF") // SUPER_ADMIN, MANAGER, STAFF (cached for JWT)
  is2FAEnabled Boolean  @default(false)
  twoFASecret  String?
  isActive     Boolean  @default(true)
  avatarUrl    String?
  createdBy    String?
  deletedAt    DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  activityLogs AdminActivityLog[]
  checkedItems RentalChecklistEntry[]
  roles        AdminUserRole[]

  @@index([tenantId])
  @@index([email])
  @@index([deletedAt])
}

model AdminActivityLog {
  id          String   @id @default(cuid())
  tenantId    String?
  adminUserId String
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([adminUserId])
  @@index([createdAt])
}

// ============================================================
// PRODUCTS & CATALOG
// ============================================================

model Category {
  id            String     @id @default(cuid())
  tenantId      String?
  name          String
  nameSwahili   String?
  slug          String
  description   String?
  imageUrl      String?
  parentId      String?
  sizeGuideId   String?
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  parent       Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children     Category[]  @relation("CategoryTree")
  products     Product[]
  sizeGuideRef SizeGuide?  @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@index([slug])
}

model Product {
  id                String   @id @default(cuid())
  tenantId          String?
  name              String
  nameSwahili       String?
  slug              String
  description       String?
  descriptionSwahili String?
  categoryId        String
  availabilityMode  String   @default("PURCHASE_ONLY") // PURCHASE_ONLY, RENTAL_ONLY, BOTH
  basePrice         Decimal  @db.Decimal(12, 2)
  compareAtPrice    Decimal? @db.Decimal(12, 2)
  sku               String?
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  sizeGuideId       String?
  specifications    Json?

  // Rental-specific fields
  // rentalPrice = flat price paid for the entire rental period (up to maxRentalDays).
  // If customer exceeds maxRentalDays, they pay a late penalty per day =
  //   latePenaltyPercent% of rentalPrice, per day late.
  // (Column name kept as rentalPricePerDay for backward compatibility but
  //  the value now represents the total flat rental price.)
  rentalPricePerDay    Decimal? @db.Decimal(12, 2)
  latePenaltyPercent   Decimal? @db.Decimal(5, 2) @default(10)
  rentalDepositAmount  Decimal? @db.Decimal(12, 2)
  rentalDownPaymentPct Int?     @default(25)
  minRentalDays        Int?
  maxRentalDays        Int?
  bufferDaysOverride   Int?

  avgRating    Float   @default(0)
  reviewCount  Int     @default(0)

  // Inventory fields
  purchasePrice     Decimal?  @db.Decimal(12, 2)
  minimumStock      Int       @default(5)
  supplierName      String?
  supplierContact   String?
  lastRestockedAt   DateTime?

  // 3D model
  model3dUrl        String?   // URL to GLB/GLTF file in /uploads/models/
  model3dPosterUrl  String?   // Optional poster image shown while 3D model loads

  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category               Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sizeGuideRef           SizeGuide?             @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  variants               ProductVariant[]
  images                 ProductImage[]
  videos                 ProductVideo[]
  reviews                Review[]
  wishlistItems          WishlistItem[]
  cartItems              CartItem[]
  orderItems             OrderItem[]
  flashSaleItems         FlashSaleItem[]
  rentalOrders           RentalOrder[]
  inventoryTransactions  InventoryTransaction[]
  events                 CustomerEvent[]

  @@unique([tenantId, slug])
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([slug])
  @@index([availabilityMode])
  @@index([isActive, isFeatured])
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String?
  productId String
  name      String  // e.g., "Red / Large"
  sku       String
  barcode   String?
  size      String?
  color     String?
  colorHex  String?
  price     Decimal @db.Decimal(12, 2)
  stock     Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cartItems    CartItem[]
  orderItems   OrderItem[]
  rentalOrders RentalOrder[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([productId])
  @@index([sku])
  @@index([barcode])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  url       String
  title     String?
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId])
}

// ============================================================
// SHOPPING CART & WISHLIST
// ============================================================

model CartItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  variantId String
  quantity  Int    @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ============================================================
// ORDERS & PAYMENTS
// ============================================================

model Order {
  id            String   @id @default(cuid())
  tenantId      String?
  orderNumber   String
  userId        String?
  addressId     String?
  status        String   @default("PENDING")
  subtotal      Decimal  @db.Decimal(12, 2)
  shippingCost  Decimal  @db.Decimal(12, 2) @default(0)
  discount      Decimal  @db.Decimal(12, 2) @default(0)
  total         Decimal  @db.Decimal(12, 2)
  paymentMethod String
  paymentStatus String   @default("PENDING")
  notes         String?

  promoCodeId   String?

  // POS fields
  channel       String   @default("ONLINE") // ONLINE, POS
  cashierId     String?
  posSessionId  String?
  customerName  String?  // Walk-in customer name (when no userId)
  customerPhone String?  // Walk-in customer phone

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  address    Address?    @relation(fields: [addressId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posSession PosSession? @relation(fields: [posSessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  promoCode  PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items      OrderItem[]
  payments   Payment[]
  shipment   Shipment?
  invoice    Invoice?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([channel])
  @@index([posSessionId])
  @@index([promoCodeId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
}

model Payment {
  id              String   @id @default(cuid())
  tenantId        String?
  orderId         String?
  rentalOrderId   String?
  layawayId       String?
  amount          Decimal  @db.Decimal(12, 2)
  method          String
  status          String   @default("PENDING")
  transactionRef  String?  @unique
  gatewayResponse Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order       Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rentalOrder RentalOrder? @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  layaway     Layaway?     @relation(fields: [layawayId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([rentalOrderId])
  @@index([layawayId])
  @@index([transactionRef])
}

model Shipment {
  id            String   @id @default(cuid())
  tenantId      String?
  orderId       String   @unique
  trackingCode  String?
  carrier       String?
  status        String   @default("PREPARING")
  shippingZoneId String?
  estimatedDelivery DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  shippingZone ShippingZone? @relation(fields: [shippingZoneId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId])
  @@index([orderId])
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String?
  orderId       String   @unique
  invoiceNumber String
  pdfUrl      String?
  issuedAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
}

// ============================================================
// SHIPPING
// ============================================================

model ShippingZone {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  regions     String[] // List of region names
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rates     ShippingRate[]
  shipments Shipment[]

  @@index([tenantId])
}

model ShippingRate {
  id             String  @id @default(cuid())
  shippingZoneId String
  name           String
  minWeight      Decimal? @db.Decimal(8, 2)
  maxWeight      Decimal? @db.Decimal(8, 2)
  minOrderAmount Decimal? @db.Decimal(12, 2)
  price          Decimal  @db.Decimal(12, 2)
  isFreeAbove    Decimal? @db.Decimal(12, 2) // Free shipping above this amount
  estimatedDays  Int?
  isActive       Boolean  @default(true)

  shippingZone ShippingZone @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([shippingZoneId])
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String
  productId  String
  rating     Int      // 1-5
  title      String?
  comment    String?
  isVerified Boolean  @default(false) // Verified purchase
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  images  ReviewImage[]

  @@unique([userId, productId])
  @@index([tenantId])
  @@index([productId])
  @@index([isApproved])
}

// ============================================================
// RENTAL SYSTEM
// ============================================================

model CustomerIDDocument {
  id               String   @id @default(cuid())
  tenantId         String?
  userId           String
  idType           String   @default("NATIONAL_ID")
  idNumber         String
  frontImageUrl    String
  backImageUrl     String?
  verificationStatus String @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason  String?
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([verificationStatus])
}

model RentalOrder {
  id               String   @id @default(cuid())
  tenantId         String?
  rentalNumber     String
  userId           String
  productId        String
  variantId        String
  startDate        DateTime
  returnDate       DateTime
  pickupDate       DateTime
  actualReturnDate DateTime?
  totalRentalPrice Decimal  @db.Decimal(12, 2)
  downPaymentAmount Decimal @db.Decimal(12, 2)
  damageDeposit    Decimal  @db.Decimal(12, 2)
  lateFee          Decimal  @db.Decimal(12, 2) @default(0)
  status           String   @default("PENDING_ID_VERIFICATION")
  notes            String?
  isReadyForPickup Boolean  @default(false)

  // Event & logistics details (admin-specified)
  pickupTime       String?            // e.g. "10:00 AM"
  weddingDate      DateTime?
  weddingLocation  String?            // venue name
  weddingRegion    String?            // region in Tanzania
  deliveryModality String?            // HAND_PICKED or SHIPPED
  shippingDate     DateTime?          // when to ship (if SHIPPED)
  shippingAddress  String?            // delivery address (if SHIPPED)
  transportMode    String?            // AIR, BUS, TRAIN, COURIER, OTHER
  transportReceiptUrl String?         // receipt from transport agent

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  payments Payment[]
  checklist RentalChecklistEntry[]
  reminders RentalPreparationReminder[]

  @@unique([tenantId, rentalNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([pickupDate])
  @@index([returnDate])
  @@index([productId, startDate, returnDate])
}

model RentalPreparationReminder {
  id            String   @id @default(cuid())
  rentalOrderId String
  sentAt        DateTime @default(now())
  daysUntilPickup Int
  sentVia       String   @default("IN_APP") // IN_APP, EMAIL, SMS

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([rentalOrderId])
}

model RentalChecklistTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items RentalChecklistTemplateItem[]

  @@index([tenantId])
}

model RentalChecklistTemplateItem {
  id         String @id @default(cuid())
  templateId String
  label      String
  labelSwahili String?
  itemType   String // DISPATCH or RETURN
  sortOrder  Int    @default(0)

  template RentalChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([templateId])
}

model RentalChecklistEntry {
  id            String    @id @default(cuid())
  rentalOrderId String
  label         String
  itemType      String    // DISPATCH or RETURN
  isChecked     Boolean   @default(false)
  checkedById   String?
  checkedAt     DateTime?
  notes         String?
  sortOrder     Int       @default(0)

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  checkedBy   AdminUser?  @relation(fields: [checkedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([rentalOrderId])
}

model RentalPolicy {
  id                           String   @id @default(cuid())
  tenantId                     String?
  bufferDaysBetweenRentals     Int      @default(7)
  defaultDownPaymentPct        Int      @default(25)
  lateFeePerDay                Decimal  @db.Decimal(12, 2) @default(10000)
  maxRentalDurationDays        Int      @default(30)
  advancePreparationReminderDays Int    @default(8)
  updatedAt                    DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// MARKETING: FLASH SALES & REFERRALS
// ============================================================

model FlashSale {
  id          String   @id @default(cuid())
  tenantId    String?
  title       String
  titleSwahili String?
  description String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items FlashSaleItem[]

  @@index([tenantId])
  @@index([startDate, endDate])
  @@index([isActive])
}

model FlashSaleItem {
  id          String  @id @default(cuid())
  flashSaleId String
  productId   String
  salePrice   Decimal @db.Decimal(12, 2)

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([flashSaleId, productId])
  @@index([flashSaleId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String   @unique
  code      String
  discount  Decimal  @db.Decimal(12, 2) @default(5000) // TZS discount
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referrals Referral[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
}

model Referral {
  id             String   @id @default(cuid())
  referralCodeId String
  referrerId     String
  referredUserId String   @unique
  isCompleted    Boolean  @default(false) // true when referred user makes first purchase
  rewardGiven    Boolean  @default(false)
  createdAt      DateTime @default(now())

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referrer     User         @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  referredUser User         @relation("referredUser", fields: [referredUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([referralCodeId])
  @@index([referrerId])
}

// ============================================================
// CMS
// ============================================================

model Banner {
  id          String   @id @default(cuid())
  tenantId    String?
  title       String
  titleSwahili String?
  subtitle    String?
  subtitleSwahili String?
  imageUrl    String
  linkUrl     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model HeroSlide {
  id          String    @id @default(cuid())
  tenantId    String?
  title       String?
  imageUrl    String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([isActive, sortOrder])
  @@index([deletedAt])
}

model Page {
  id             String   @id @default(cuid())
  tenantId       String?
  title          String
  titleSwahili   String?
  slug           String
  content        String
  contentSwahili String?
  isPublished    Boolean  @default(false)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
}

model SizeGuide {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  nameSwahili      String?
  slug             String
  content          String
  contentSwahili   String?
  pdfUrl           String?
  pdfUrlSwahili    String?
  isDefault        Boolean   @default(false)
  isActive         Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products   Product[]
  categories Category[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
  @@index([isDefault])
  @@index([deletedAt])
}

model SiteSetting {
  id       String  @id @default(cuid())
  tenantId String?
  key      String
  value    String
  type     String  @default("string") // string, json, boolean, number

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([key])
}

model InstagramPost {
  id               String    @id @default(cuid())
  tenantId         String?
  caption          String?
  imageUrl         String
  postUrl          String?
  likes            Int       @default(0)
  sortOrder        Int       @default(0)
  isActive         Boolean   @default(true)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Source & ordering
  source           String    @default("MANUAL") // INSTAGRAM_API or MANUAL
  isPinned         Boolean   @default(false)
  instagramMediaId String?   @unique
  mediaType        String?   // IMAGE, VIDEO, CAROUSEL_ALBUM
  postedAt         DateTime?

  @@index([tenantId])
  @@index([isActive, sortOrder])
  @@index([deletedAt])
  @@index([source])
  @@index([isPinned])
}

// ============================================================
// NEWSLETTER
// ============================================================

model NewsletterSubscriber {
  id               String    @id @default(cuid())
  tenantId         String?
  email            String
  name             String?
  isActive         Boolean   @default(true)
  source           String    @default("STOREFRONT") // STOREFRONT, ADMIN, IMPORT
  unsubscribeToken String    @unique @default(cuid())
  subscribedAt     DateTime  @default(now())
  unsubscribedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  deliveries NewsletterDelivery[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([isActive])
  @@index([unsubscribeToken])
}

model Newsletter {
  id           String    @id @default(cuid())
  tenantId     String?
  subject      String
  bodyHtml     String
  templateType String    @default("CUSTOM") // NEW_ARRIVALS, NEW_DEALS, TIPS, CUSTOM
  status       String    @default("DRAFT")  // DRAFT, SENDING, SENT, FAILED
  sentAt       DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deliveries NewsletterDelivery[]
  products   NewsletterProduct[]

  @@index([tenantId])
  @@index([status])
  @@index([templateType])
  @@index([createdAt])
}

model NewsletterDelivery {
  id            String    @id @default(cuid())
  newsletterId  String
  subscriberId  String
  status        String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())

  newsletter Newsletter           @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([newsletterId, subscriberId])
  @@index([newsletterId])
  @@index([subscriberId])
  @@index([status])
}

model NewsletterProduct {
  id           String   @id @default(cuid())
  newsletterId String
  productId    String
  createdAt    DateTime @default(now())

  newsletter Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@unique([newsletterId, productId])
  @@index([newsletterId])
  @@index([productId])
}

// ============================================================
// PICKUP POINTS
// ============================================================

model PickupPoint {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  address     String
  city        String
  region      String
  phone       String?
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// INVENTORY
// ============================================================

model InventoryTransaction {
  id             String   @id @default(cuid())
  tenantId       String?
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  type           String   // RESTOCK|SALE|RENTAL_OUT|RENTAL_RETURN|ADJUSTMENT|DAMAGE
  quantityBefore Int
  quantityChange Int      // positive=in, negative=out
  quantityAfter  Int
  unitCost       Decimal? @db.Decimal(12, 2)
  totalValue     Decimal? @db.Decimal(12, 2)
  reference      String?
  note           String?
  performedBy    String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// FINANCIALS
// ============================================================

model ExpenseCategory {
  id           String            @id @default(cuid())
  tenantId     String?
  name         String
  description  String?
  categoryType String            @default("OPERATING") // COGS|OPERATING|TAX|OTHER
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  expenses     BusinessExpense[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
}

model BusinessExpense {
  id          String          @id @default(cuid())
  tenantId    String?
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  vendor      String?
  expenseDate DateTime
  period      String          // "YYYY-MM" auto-computed
  receiptUrl  String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId])
  @@index([categoryId])
  @@index([period])
  @@index([expenseDate])
}

model FinancialPeriod {
  id         String    @id @default(cuid())
  tenantId   String?
  periodKey  String                // "YYYY-MM"
  periodName String
  startDate  DateTime
  endDate    DateTime
  periodType String    @default("MONTH")
  status     String    @default("OPEN")  // OPEN|CLOSED|LOCKED
  closedBy   String?
  closedAt   DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, periodKey])
  @@index([tenantId])
  @@index([periodKey])
  @@index([status])
}

// ============================================================
// RBAC (Permissions, Roles, AdminUserRole)
// ============================================================

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique  // e.g. "products:create"
  name        String
  description String?
  module      String
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@index([module])
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  adminUsers  AdminUserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
}

model AdminUserRole {
  adminUserId String
  roleId      String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt  DateTime  @default(now())
  assignedBy  String?

  @@id([adminUserId, roleId])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  tenantId    String?
  email       String
  isAdmin     Boolean
  success     Boolean
  ipAddress   String?
  userAgent   String?
  attemptedAt DateTime @default(now())

  @@index([tenantId])
  @@index([email])
  @@index([attemptedAt])
}

// ============================================================
// CUSTOMER EVENTS / GALLERY
// ============================================================

model CustomerEvent {
  id                 String    @id @default(cuid())
  tenantId           String?
  title              String
  titleSwahili       String?
  slug               String
  description        String?
  descriptionSwahili String?
  eventDate          DateTime
  location           String?
  customerName       String?
  socialLinks        Json?     // { instagram, facebook, tiktok }
  coverImageUrl      String?

  // Ownership
  userId             String?
  productId          String?
  createdByAdminId   String?

  // Approval workflow
  status             String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED
  rejectionReason    String?
  approvedAt         DateTime?
  approvedById       String?

  isFeatured         Boolean   @default(false)
  sortOrder          Int       @default(0)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  media   EventMedia[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([eventDate])
  @@index([deletedAt])
  @@index([slug])
}

model EventMedia {
  id           String   @id @default(cuid())
  eventId      String
  url          String
  thumbnailUrl String?
  mediaType    String   @default("IMAGE") // IMAGE, VIDEO
  altText      String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  event CustomerEvent @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([eventId])
}

// ============================================================
// POINT OF SALE (POS)
// ============================================================

model PosSession {
  id             String    @id @default(cuid())
  tenantId       String?
  adminUserId    String
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingCash    Decimal   @db.Decimal(12, 2) @default(0)
  closingCash    Decimal?  @db.Decimal(12, 2)
  expectedCash   Decimal?  @db.Decimal(12, 2)
  cashDifference Decimal?  @db.Decimal(12, 2)
  totalSales     Decimal   @db.Decimal(12, 2) @default(0)
  totalTransactions Int    @default(0)
  notes          String?
  status         String    @default("OPEN") // OPEN, CLOSED

  orders   Order[]
  layaways Layaway[]

  @@index([tenantId])
  @@index([adminUserId])
  @@index([status])
  @@index([openedAt])
}

model HeldSale {
  id           String   @id @default(cuid())
  tenantId     String?
  adminUserId  String
  customerId   String?
  customerName String?
  customerPhone String?
  items        Json     // Array of {productId, variantId, productName, variantName, quantity, unitPrice, itemDiscount}
  discount     Decimal  @db.Decimal(12, 2) @default(0)
  discountType String?  // PERCENTAGE, FIXED
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([adminUserId])
}

model Layaway {
  id             String    @id @default(cuid())
  tenantId       String?
  layawayNumber  String
  customerId     String
  cashierId      String
  posSessionId   String?
  items          Json      // Same shape as HeldSale items
  subtotal       Decimal   @db.Decimal(12, 2)
  discount       Decimal   @db.Decimal(12, 2) @default(0)
  discountType   String?   // PERCENTAGE, FIXED
  total          Decimal   @db.Decimal(12, 2)
  depositAmount  Decimal   @db.Decimal(12, 2)
  depositPaid    Decimal   @db.Decimal(12, 2) @default(0)
  balanceDue     Decimal   @db.Decimal(12, 2)
  dueDate        DateTime
  status         String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  completedAt    DateTime?
  cancelledAt    DateTime?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer   User        @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posSession PosSession? @relation(fields: [posSessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payments   Payment[]

  @@unique([tenantId, layawayNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([posSessionId])
}

model PosExchange {
  id               String   @id @default(cuid())
  tenantId         String?
  exchangeNumber   String
  originalOrderId  String
  newOrderId       String?
  cashierId        String
  posSessionId     String?
  customerId       String?
  returnedItems    Json     // [{orderItemId, productId, variantId, productName, variantName, quantity, unitPrice}]
  returnTotal      Decimal  @db.Decimal(12, 2)
  newItems         Json?    // [{productId, variantId, productName, variantName, quantity, unitPrice}]
  newTotal         Decimal  @db.Decimal(12, 2) @default(0)
  priceDifference  Decimal  @db.Decimal(12, 2) @default(0) // positive = customer owes, negative = refund
  settlementMethod String?  // CASH, MPESA, TIGO_PESA, AIRTEL_MONEY, MIX_BY_YAS, CARD
  settlementAmount Decimal? @db.Decimal(12, 2)
  reason           String?
  note             String?
  createdAt        DateTime @default(now())

  @@unique([tenantId, exchangeNumber])
  @@index([tenantId])
  @@index([originalOrderId])
  @@index([cashierId])
  @@index([createdAt])
}

// ============================================================
// PROMO CODES & COUPONS
// ============================================================

model PromoCode {
  id                 String    @id @default(cuid())
  tenantId           String?
  code               String
  description        String?
  discountType       String    // PERCENTAGE, FIXED
  discountValue      Decimal   @db.Decimal(12, 2) // percentage (0-100) or fixed amount
  minOrderAmount     Decimal?  @db.Decimal(12, 2) // minimum order to qualify
  maxDiscountAmount  Decimal?  @db.Decimal(12, 2) // cap for percentage discounts
  maxUses            Int?      // total uses allowed (null = unlimited)
  maxUsesPerUser     Int       @default(1) // per-user limit
  usedCount          Int       @default(0)
  validFrom          DateTime  @default(now())
  validUntil         DateTime?
  isActive           Boolean   @default(true)
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  usages   PromoCodeUsage[]
  orders   Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@index([isActive])
  @@index([validFrom, validUntil])
}

model PromoCodeUsage {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  orderId     String?
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([promoCodeId, orderId])
  @@index([userId])
  @@index([promoCodeId])
}

// ============================================================
// REVIEW IMAGES
// ============================================================

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([reviewId])
}

// ============================================================
// CONTACT SUBMISSIONS
// ============================================================

model ContactSubmission {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  email       String
  phone       String?
  subject     String?
  message     String
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, CLOSED, UNATTENDED
  adminReply  String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// ============================================================
// ABANDONED CART TRACKING
// ============================================================

model AbandonedCartReminder {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  cartTotal Decimal? @db.Decimal(12, 2)
  itemCount Int      @default(0)
  sentAt    DateTime @default(now())
  channel   String   @default("EMAIL") // EMAIL, WHATSAPP, SMS
  sequence  Int      @default(1) // 1=1hr, 2=24hr, 3=72hr

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([sentAt])
}

// ============================================================
// PAYMENT METHODS
// ============================================================

model PaymentMethod {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  code             String
  description      String?
  iconUrl          String?
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  integrationKey   String?
  integrationParams Json?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([sortOrder])
}
