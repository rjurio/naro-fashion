  customerPhone String?
  items        Json     // Array of {productId, variantId, productName, variantName, quantity, unitPrice, itemDiscount}
  discount     Decimal  @db.Decimal(12, 2) @default(0)
  discountType String?  // PERCENTAGE, FIXED
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([adminUserId])
}

model Layaway {
  id             String    @id @default(cuid())
  tenantId       String?
  layawayNumber  String
  customerId     String
  cashierId      String
  posSessionId   String?
  items          Json      // Same shape as HeldSale items
  subtotal       Decimal   @db.Decimal(12, 2)
  discount       Decimal   @db.Decimal(12, 2) @default(0)
  discountType   String?   // PERCENTAGE, FIXED
  total          Decimal   @db.Decimal(12, 2)
  depositAmount  Decimal   @db.Decimal(12, 2)
  depositPaid    Decimal   @db.Decimal(12, 2) @default(0)
  balanceDue     Decimal   @db.Decimal(12, 2)
  dueDate        DateTime
  status         String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, EXPIRED
  completedAt    DateTime?
  cancelledAt    DateTime?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer   User        @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posSession PosSession? @relation(fields: [posSessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payments   Payment[]

  @@unique([tenantId, layawayNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([posSessionId])
}

model PosExchange {
  id               String   @id @default(cuid())
  tenantId         String?
  exchangeNumber   String
  originalOrderId  String
  newOrderId       String?
  cashierId        String
  posSessionId     String?
  customerId       String?
  returnedItems    Json     // [{orderItemId, productId, variantId, productName, variantName, quantity, unitPrice}]
  returnTotal      Decimal  @db.Decimal(12, 2)
  newItems         Json?    // [{productId, variantId, productName, variantName, quantity, unitPrice}]
  newTotal         Decimal  @db.Decimal(12, 2) @default(0)
  priceDifference  Decimal  @db.Decimal(12, 2) @default(0) // positive = customer owes, negative = refund
  settlementMethod String?  // CASH, MPESA, TIGO_PESA, AIRTEL_MONEY, MIX_BY_YAS, CARD
  settlementAmount Decimal? @db.Decimal(12, 2)
  reason           String?
  note             String?
  createdAt        DateTime @default(now())

  @@unique([tenantId, exchangeNumber])
  @@index([tenantId])
  @@index([originalOrderId])
  @@index([cashierId])
  @@index([createdAt])
}

// ============================================================
// PROMO CODES & COUPONS
// ============================================================

model PromoCode {
  id                 String    @id @default(cuid())
  tenantId           String?
  code               String
  description        String?
  discountType       String    // PERCENTAGE, FIXED
  discountValue      Decimal   @db.Decimal(12, 2) // percentage (0-100) or fixed amount
  minOrderAmount     Decimal?  @db.Decimal(12, 2) // minimum order to qualify
  maxDiscountAmount  Decimal?  @db.Decimal(12, 2) // cap for percentage discounts
  maxUses            Int?      // total uses allowed (null = unlimited)
  maxUsesPerUser     Int       @default(1) // per-user limit
  usedCount          Int       @default(0)
  validFrom          DateTime  @default(now())
  validUntil         DateTime?
  isActive           Boolean   @default(true)
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  usages   PromoCodeUsage[]
  orders   Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
  @@index([isActive])
  @@index([validFrom, validUntil])
}

model PromoCodeUsage {
  id          String   @id @default(cuid())
  promoCodeId String
  userId      String
  orderId     String?
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([promoCodeId, orderId])
  @@index([userId])
  @@index([promoCodeId])
}

// ============================================================
// REVIEW IMAGES
// ============================================================

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([reviewId])
}

// ============================================================
// CONTACT SUBMISSIONS
// ============================================================

model ContactSubmission {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  email       String
  phone       String?
  subject     String?
  message     String
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, CLOSED, UNATTENDED
  adminReply  String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// ============================================================
// ABANDONED CART TRACKING
// ============================================================

model AbandonedCartReminder {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  cartTotal Decimal? @db.Decimal(12, 2)
  itemCount Int      @default(0)
  sentAt    DateTime @default(now())
  channel   String   @default("EMAIL") // EMAIL, WHATSAPP, SMS
  sequence  Int      @default(1) // 1=1hr, 2=24hr, 3=72hr

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([sentAt])
}

// ============================================================
// PAYMENT METHODS
// ============================================================

model PaymentMethod {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  code             String
  description      String?
  iconUrl          String?
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  integrationKey   String?
  integrationParams Json?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([sortOrder])
}
