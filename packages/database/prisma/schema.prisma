generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?   @unique   // Custom domain, e.g. "shop.narofashion.co.tz"
  status      String    @default("ACTIVE") // ACTIVE, TRIAL, SUSPENDED, DEACTIVATED
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branding      TenantBranding?
  subscriptions TenantSubscription[]
  payments      TenantPayment[]
  modules       TenantModule[]
  adminUsers    AdminUser[]
  users         User[]

  @@index([slug])
  @@index([domain])
  @@index([status])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("PLATFORM_ADMIN") // PLATFORM_ADMIN, PLATFORM_SUPPORT
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model TenantBranding {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  companyName     String
  tagline         String?
  logoUrl         String?
  iconUrl         String?
  faviconUrl      String?
  colorPrimary    String  @default("#D4AF37")
  colorSecondary  String  @default("#1A1A1A")
  colorAccent     String  @default("#D4AF37")
  fontHeading     String  @default("Playfair Display")
  fontBody        String  @default("Inter")
  customCss       String?
  whatsappNumber  String?
  socialLinks     Json?     // { instagram, facebook, tiktok, twitter }
  metaTitle       String?
  metaDescription String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  priceMonthly   Decimal  @db.Decimal(12, 2)
  priceYearly    Decimal? @db.Decimal(12, 2)
  maxProducts    Int?                          // null = unlimited
  maxAdminUsers  Int?
  maxStorageGB   Int      @default(5)
  enabledModules String[]                      // ["products","orders","rentals","pos",...]
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id           String    @id @default(cuid())
  tenantId     String
  planId       String
  status       String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED, GRACE
  billingCycle String    @default("MONTHLY") // MONTHLY, YEARLY
  startDate    DateTime  @default(now())
  endDate      DateTime
  autoRenew    Boolean   @default(true)
  graceEndDate DateTime?                    // End of grace period after expiry
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([endDate])
  @@index([status])
}

model TenantPayment {
  id             String    @id @default(cuid())
  tenantId       String
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("TZS")
  method         String                         // MOBILE_MONEY, BANK_TRANSFER, MANUAL
  status         String    @default("PENDING")  // PENDING, COMPLETED, FAILED
  transactionRef String?   @unique
  invoiceNumber  String?   @unique
  periodStart    DateTime
  periodEnd      DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([status])
}

model TenantModule {
  id         String   @id @default(cuid())
  tenantId   String
  moduleCode String                            // "products", "orders", "rentals", "pos", etc.
  isEnabled  Boolean  @default(true)
  enabledAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, moduleCode])
  @@index([tenantId])
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  email         String?
  phone         String?
  passwordHash  String?
  firstName     String?
  lastName      String?
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  preferredTheme String   @default("standard")
  preferredLocale String  @default("en")
  googleId      String?   @unique
  facebookId    String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  rentalOrders  RentalOrder[]
  idDocuments   CustomerIDDocument[]
  referralCode  ReferralCode?
  referredBy    Referral?       @relation("referredUser")
  referrals     Referral[]      @relation("referrer")
  events        CustomerEvent[]
  layaways      Layaway[]
  promoCodeUsages PromoCodeUsage[]
  abandonedCartReminders AbandonedCartReminder[]

  alternativePhone String?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  label       String  @default("Home")
  fullName    String
  phone       String
  street      String
  city        String
  region      String
  postalCode  String?
  country     String  @default("Tanzania")
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orders Order[]

  @@index([userId])
}

model AdminUser {
  id           String   @id @default(cuid())
  tenantId     String?
  email        String   @unique  // Globally unique — no tenant context needed at admin login
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         String   @default("STAFF") // SUPER_ADMIN, MANAGER, STAFF (cached for JWT)
  is2FAEnabled Boolean  @default(false)
  twoFASecret  String?
  isActive     Boolean  @default(true)
  avatarUrl    String?
  createdBy    String?
  deletedAt    DateTime?

  // Account lockout
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  activityLogs AdminActivityLog[]
  agentAuditLogs AgentAuditLog[]
  agentApprovalsRequested AgentApprovalRequest[] @relation("AgentApprovalRequestedBy")
  agentApprovalsApproved  AgentApprovalRequest[] @relation("AgentApprovalApprovedBy")
  checkedItems RentalChecklistEntry[]
  roles        AdminUserRole[]

  @@index([tenantId])
  @@index([email])
  @@index([deletedAt])
}

model AdminActivityLog {
  id          String   @id @default(cuid())
  tenantId    String?
  adminUserId String
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([tenantId])
  @@index([adminUserId])
  @@index([createdAt])
}

// AI agent audit log — one row per AI tool invocation (read or write,
// success or failure). Sits alongside AdminActivityLog rather than
// replacing it: write actions also push a summary into AdminActivityLog
// so the existing /audit page surfaces AI activity. AgentAuditLog stores
// the richer fields (sanitised input/output, approval link, severity)
// that the existing schema doesn't carry.
model AgentAuditLog {
  id                  String   @id @default(cuid())
  tenantId            String?
  adminUserId         String
  agentName           String   @default("naro-fashion-admin")
  sessionId           String?
  toolName            String
  actionType          String   @default("READ") // READ | CREATE | UPDATE | DELETE | RESTORE | PUBLISH | ARCHIVE | STATUS_CHANGE | ADJUST_INVENTORY | NOTE | APPROVAL_REQUESTED | APPROVAL_GRANTED | APPROVAL_REJECTED | APPROVAL_REVOKED | APPROVAL_CANCELLED | APPROVAL_EXPIRED | APPROVAL_EXHAUSTED
  targetResourceType  String?
  targetResourceId    String?
  inputJson           Json?
  outputJson          Json?
  approvalRequired    Boolean  @default(false)
  approvalStatus      String   @default("NOT_REQUIRED") // NOT_REQUIRED | PENDING | APPROVED | REJECTED | EXPIRED | CONSUMED | CANCELLED | REVOKED | EXHAUSTED
  approvalRequestId   String?  // Links a write/approval audit row to its AgentApprovalRequest (Phase 3.0+). Null for Phase 1/2 reads + drafts.
  status              String   // SUCCESS | FAILED | REJECTED | UNAUTHORIZED | VALIDATION_ERROR | PERMISSION_DENIED | MODULE_DISABLED
  errorMessage        String?
  severity            String   @default("INFO") // INFO | NOTICE | WARNING | CRITICAL
  ipAddress           String?
  userAgent           String?
  durationMs          Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  adminUser       AdminUser             @relation(fields: [adminUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  approvalRequest AgentApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId, createdAt])
  @@index([adminUserId, createdAt])
  @@index([toolName])
  @@index([targetResourceType, targetResourceId])
  @@index([severity])
  @@index([approvalRequestId])
}

// AI agent approval request (Phase 3.0+).
// Lifecycle: PENDING → APPROVED → CONSUMED (happy path)
//                  → REJECTED | CANCELLED | REVOKED | EXPIRED | EXHAUSTED (terminal failure paths)
//
// Token storage: only `approvalTokenHash` (sha256 of the raw token) is persisted.
// Raw token is returned to the approver once and never logged. See
// docs/ai-agent/PHASE_3_DESIGN.md §5 + Decision Log #6.
//
// No risky tools currently consume this model — Phase 3.0 ships the
// schema only. Phase 3.1 wires the approval flow.
model AgentApprovalRequest {
  id                       String    @id @default(cuid())
  tenantId                 String?

  // ─── Identity ────────────────────────────────────────────────────────
  requestedByAdminUserId   String                                     // initiator
  approvedByAdminUserId    String?                                    // populated when status flips out of PENDING

  // ─── Tool + payload ──────────────────────────────────────────────────
  toolName                 String                                     // e.g. "publish_product"
  targetResourceType       String?
  targetResourceId         String?
  targetResourceName       String?                                    // human-readable label, e.g. "Floral Mermaid Gown"
  inputJson                Json                                       // sanitised input — same rules as AgentAuditLog
  payloadHash              String                                     // sha256(toolName || canonicalJSON(input))

  // ─── Approval summary snapshot (frozen at request time) ──────────────
  actionTitle              String                                     // short verb, e.g. "Publish wedding gown"
  businessSummary          String                                     // one-line plain-English explanation
  riskLevel                String                                     // LOW | MEDIUM | HIGH | CRITICAL
  beforeValues             Json?                                      // resource snapshot BEFORE the action
  afterValues              Json?                                      // proposed values AFTER the action
  expectedUpdatedAt        DateTime?                                  // resource.updatedAt at request time (stale-data guard)

  // ─── Token (HASHED ONLY — never raw) ─────────────────────────────────
  approvalTokenHash        String?   @unique                          // sha256(rawToken). Cleared on consume/revoke/exhaust.

  // ─── State machine ───────────────────────────────────────────────────
  status                   String    @default("PENDING")              // PENDING | APPROVED | REJECTED | CANCELLED | REVOKED | CONSUMED | EXPIRED | EXHAUSTED
  rejectionReason          String?
  expirationReason         String?                                    // 'ttl' | 'stale_data' | 'payload_mismatch' (when status=EXPIRED)
  executionAttempts        Int       @default(0)                      // consume retries; capped at 3

  // ─── Lifecycle timestamps ────────────────────────────────────────────
  expiresAt                DateTime
  approvedAt               DateTime?
  rejectedAt               DateTime?
  cancelledAt              DateTime?
  revokedAt                DateTime?
  consumedAt               DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  requestedBy AdminUser  @relation("AgentApprovalRequestedBy", fields: [requestedByAdminUserId], references: [id], onDelete: Cascade)
  approvedBy  AdminUser? @relation("AgentApprovalApprovedBy",  fields: [approvedByAdminUserId],  references: [id], onDelete: SetNull)
  auditLogs   AgentAuditLog[]

  @@index([tenantId, status])
  @@index([requestedByAdminUserId, createdAt])
  @@index([approvedByAdminUserId, createdAt])
  @@index([expiresAt])
  @@index([riskLevel, status])
}

// ============================================================
// PRODUCTS & CATALOG
// ============================================================

model Category {
  id            String     @id @default(cuid())
  tenantId      String?
  name          String
  nameSwahili   String?
  slug          String
  description   String?
  imageUrl      String?
  parentId      String?
  sizeGuideId   String?
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  parent       Category?   @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children     Category[]  @relation("CategoryTree")
  products     Product[]
  sizeGuideRef SizeGuide?  @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@index([slug])
}

model Product {
  id                String   @id @default(cuid())
  tenantId          String?
  name              String
  nameSwahili       String?
  slug              String
  description       String?
  descriptionSwahili String?
  categoryId        String
  availabilityMode  String   @default("PURCHASE_ONLY") // PURCHASE_ONLY, RENTAL_ONLY, BOTH
  basePrice         Decimal  @db.Decimal(12, 2)
  compareAtPrice    Decimal? @db.Decimal(12, 2)
  sku               String?
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  sizeGuideId       String?
  specifications    Json?

  // Rental-specific fields
  // rentalPrice = flat price paid for the entire rental period (up to maxRentalDays).
  // If customer exceeds maxRentalDays, they pay a late penalty per day =
  //   latePenaltyPercent% of rentalPrice, per day late.
  // (Column name kept as rentalPricePerDay for backward compatibility but
  //  the value now represents the total flat rental price.)
  rentalPricePerDay    Decimal? @db.Decimal(12, 2)
  latePenaltyPercent   Decimal? @db.Decimal(5, 2) @default(10)
  rentalDepositAmount  Decimal? @db.Decimal(12, 2)
  rentalDownPaymentPct Int?     @default(25)
  minRentalDays        Int?
  maxRentalDays        Int?
  bufferDaysOverride   Int?

  avgRating    Float   @default(0)
  reviewCount  Int     @default(0)

  // Inventory fields
  purchasePrice     Decimal?  @db.Decimal(12, 2)
  minimumStock      Int       @default(5)
  supplierName      String?
  supplierContact   String?
  lastRestockedAt   DateTime?

  // 3D model
  model3dUrl        String?   // URL to GLB/GLTF file in /uploads/models/
  model3dPosterUrl  String?   // Optional poster image shown while 3D model loads

  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category               Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sizeGuideRef           SizeGuide?             @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  variants               ProductVariant[]
  images                 ProductImage[]
  videos                 ProductVideo[]
  reviews                Review[]
  wishlistItems          WishlistItem[]
  cartItems              CartItem[]
  orderItems             OrderItem[]
  flashSaleItems         FlashSaleItem[]
  rentalOrders           RentalOrder[]
  inventoryTransactions  InventoryTransaction[]
  events                 CustomerEvent[]

  @@unique([tenantId, slug])
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([slug])
  @@index([availabilityMode])
  @@index([isActive, isFeatured])
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String?
  productId String
  name      String  // e.g., "Red / Large"
  sku       String
  barcode   String?
  size      String?
  color     String?
  colorHex  String?
  price     Decimal @db.Decimal(12, 2)
  stock     Int     @default(0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cartItems    CartItem[]
  orderItems   OrderItem[]
  rentalOrders RentalOrder[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([productId])
  @@index([sku])
  @@index([barcode])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  url       String
  title     String?
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId])
}

// ============================================================
// SHOPPING CART & WISHLIST
// ============================================================

model CartItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  variantId String
  quantity  Int    @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ============================================================
// ORDERS & PAYMENTS
// ============================================================

model Order {
  id            String   @id @default(cuid())
  tenantId      String?
  orderNumber   String
  userId        String?
  addressId     String?
  status        String   @default("PENDING")
  subtotal      Decimal  @db.Decimal(12, 2)
  shippingCost  Decimal  @db.Decimal(12, 2) @default(0)
  discount      Decimal  @db.Decimal(12, 2) @default(0)
  total         Decimal  @db.Decimal(12, 2)
  paymentMethod String
  paymentStatus String   @default("PENDING")
  notes         String?

  promoCodeId   String?

  // POS fields
  channel       String   @default("ONLINE") // ONLINE, POS
  cashierId     String?
  posSessionId  String?
  customerName  String?  // Walk-in customer name (when no userId)
  customerPhone String?  // Walk-in customer phone

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  address    Address?    @relation(fields: [addressId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  posSession PosSession? @relation(fields: [posSessionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  promoCode  PromoCode?  @relation(fields: [promoCodeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  items      OrderItem[]
  payments   Payment[]
  shipment   Shipment?
  invoice    Invoice?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([channel])
  @@index([posSessionId])
  @@index([promoCodeId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([orderId])
}

model Payment {
  id                    String    @id @default(cuid())
  tenantId              String?
  orderId               String?
  rentalOrderId         String?
  layawayId             String?
  amount                Decimal   @db.Decimal(12, 2)
  method                String
  status                String    @default("PENDING")
  transactionRef        String?   @unique
  providerCode          String?
  providerTransactionId String?
  lastPolledAt          DateTime?
  gatewayResponse       Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  order       Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rentalOrder RentalOrder? @relation(fields: [rentalOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  layaway     Layaway?     @relation(fields: [layawayId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([rentalOrderId])
  @@index([layawayId])
  @@index([transactionRef])
  @@index([providerCode, status])
  @@index([providerTransactionId])
}

model WebhookEvent {
  id              String   @id @default(cuid())
  tenantId        String?
  providerCode    String
  providerEventId String
  eventType       String
  orderReference  String?
  checksumValid   Boolean?
  rawPayload      Json
  processed       Boolean  @default(false)
  receivedAt      DateTime @default(now())

  @@unique([providerCode, providerEventId, eventType])
  @@index([tenantId, orderReference])
  @@index([providerCode, processed])
}

model Shipment {
  id            String   @id @default(cuid())
  tenantId      String?
  orderId       String   @unique
  trackingCode  String?
  carrier       String?
  status        String   @default("PREPARING")
  shippingZoneId String?
  estimatedDelivery DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  shippingZone ShippingZone? @relation(fields: [shippingZoneId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tenantId])
  @@index([orderId])
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String?
  orderId       String   @unique
  invoiceNumber String
  pdfUrl      String?
  issuedAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
}

// ============================================================
// SHIPPING
// ============================================================

model ShippingZone {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  regions     String[] // List of region names
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rates     ShippingRate[]
  shipments Shipment[]

  @@index([tenantId])
}

model ShippingRate {
  id             String  @id @default(cuid())
  shippingZoneId String
  name           String
  minWeight      Decimal? @db.Decimal(8, 2)
  maxWeight      Decimal? @db.Decimal(8, 2)
