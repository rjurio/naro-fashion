<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{subject}}</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f5f5f5;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333333;
    }
    .email-wrapper {
      max-width: 600px;
      margin: 0 auto;
      background-color: #ffffff;
    }
    .email-header {
      background-color: #1A1A1A;
      padding: 24px 32px;
      text-align: center;
    }
    .email-header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 2px;
    }
    .brand-naro {
      color: #D4AF37;
    }
    .brand-fashion {
      color: #ffffff;
    }
    .email-body {
      padding: 32px;
      line-height: 1.6;
      font-size: 15px;
    }
    .email-footer {
      background-color: #1A1A1A;
      padding: 20px 32px;
      text-align: center;
      font-size: 12px;
      color: #999999;
    }
    .email-footer a {
      color: #D4AF37;
      text-decoration: none;
    }
    .gold-divider {
      height: 3px;
      background-color: #D4AF37;
      border: none;
      margin: 0;
    }
    .btn-primary {
      display: inline-block;
      padding: 12px 32px;
      background-color: #D4AF37;
      color: #1A1A1A;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      border-radius: 4px;
      margin: 16px 0;
    }
    .info-box {
      background-color: #f9f7f0;
      border-left: 4px solid #D4AF37;
      padding: 16px 20px;
      margin: 20px 0;
      border-radius: 0 4px 4px 0;
    }
    .info-box p {
      margin: 4px 0;
    }
    .label {
      font-weight: 600;
      color: #1A1A1A;
    }
  </style>
</head>
<body>
  <div class="email-wrapper">
    <div class="email-header">
      <h1 style="color: #D4AF37;">{{businessName}}</h1>
    </div>
    <hr class="gold-divider" />
    <div class="email-body">
      {{{body}}}
    </div>
    <hr class="gold-divider" />
    <div class="email-footer">
      <p>&copy; {{year}} {{businessName}}. All rights reserved.</p>
      <p>
        <a href="{{storeUrl}}">Visit Our Store</a>
      </p>
      <p style="margin-top: 12px; font-size: 11px; color: #666666;">
        You are receiving this email because you have an account with {{businessName}}.
      </p>
    </div>
  </div>
</body>
</html>
